# ─── GCP / Firebase Identity ─────────────────────────────────────────────────
# Your Google Cloud project ID (visible in GCP Console → Project info)
GCP_PROJECT_ID=my-gcp-project

# Your Firebase project ID (same as GCP project ID in most cases)
FIREBASE_PROJECT_ID=my-gcp-project

# ─── Service Account Key ──────────────────────────────────────────────────────
# Path to the JSON key for the service account that the API uses at runtime.
# Run `python scripts/setup_service_account.py` to generate this file.
GOOGLE_APPLICATION_CREDENTIALS=credentials/app-key.json

# ─── Export Service Account ───────────────────────────────────────────────────
# Name of the service account that will be created / configured to read exports.
# Changing this after initial provisioning will create a second service account.
EXPORT_SERVICE_ACCOUNT_NAME=crashlytics-bq-reader
EXPORT_SERVICE_ACCOUNT_DISPLAY_NAME=Crashlytics BigQuery Reader

# ─── BigQuery Export Dataset ─────────────────────────────────────────────────
# Firebase always creates this dataset as `firebase_crashlytics` in your project.
BIGQUERY_DATASET_ID=firebase_crashlytics
BIGQUERY_LOCATION=US

# ─── App Identifier ───────────────────────────────────────────────────────────
# The package name / bundle ID of your app, exactly as registered in Firebase.
# Dots and hyphens are replaced with underscores for BigQuery table names
# (e.g. "com.example.myapp" → table prefix "com_example_myapp").
APP_PACKAGE_NAME=com.example.myapp

# ─── IAM Roles (JSON list) ───────────────────────────────────────────────────
# Roles granted to the export service account on the GCP project.
# Defaults are sufficient for read-only crash data access.
EXPORT_IAM_ROLES=["roles/bigquery.dataViewer","roles/bigquery.jobUser","roles/bigquery.metadataViewer"]
